{
  "name": "Entroly Dev",
  "image": "mcr.microsoft.com/devcontainers/rust:1",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    }
  },
  "postCreateCommand": "pip install maturin && pip install -e '.[full]' && cd entroly-core && maturin develop --release",
  "forwardPorts": [9377, 9378],
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "ms-python.python"
      ]
    }
  }
}
